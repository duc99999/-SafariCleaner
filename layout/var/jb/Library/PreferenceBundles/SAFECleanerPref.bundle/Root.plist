<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>title</key>
    <string>Safari Cleaner</string>
    <key>items</key>
    <array>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>One-tap Safari data wipe</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSButtonCell</string>
            <key>label</key>
            <string>Wipe Safari Now</string>
            <key>action</key>
            <string>wipeSafari:</string>
            <key>isDestructive</key>
            <true/>
            <key>alignment</key>
            <string>1</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Options</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSSwitchCell</string>
            <key>label</key>
            <string>Keep backup after wipe</string>
            <key>defaults</key>
            <string>com.duc.safecleaner</string>
            <key>key</key>
            <string>keepBackup</string>
            <key>default</key>
            <true/>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>label</key>
            <string>Backups</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSButtonCell</string>
            <key>label</key>
            <string>Open Backups Folder</string>
            <key>action</key>
            <string>openBackupsFolder:</string>
        </dict>
        <dict>
            <key>cell</key>
            <string>PSGroupCell</string>
            <key>footerText</key>
            <string>SAFECleanerEngine xóa toàn bộ: Cookies, WebKit storage, IndexedDB, LocalStorage, SessionStorage, Service Worker, History, Reading List, Tabs, Bookmarks, Autofill, Recently visited tiles, SSL session cache và cfprefsd state cho Safari/WebKit.

Sau khi wipe xong tweak sẽ mở lại Safari với profile trống.

Khuyến nghị: đăng xuất mọi tài khoản quan trọng trước khi wipe.</string>
        </dict>
    </array>
</dict>
</plist>